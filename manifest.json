{
  "manifest_version": 3,
  "name": "Vinted Relist Assistant",
  "version": "1.0.0",
  "description": "Helps you manually relist Vinted items safely with delays and human-controlled confirmations.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "notifications",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.vinted.com/*",
    "*://*.vinted.fr/*",
    "*://*.vinted.de/*",
    "*://*.vinted.co.uk/*",
    "*://*.vinted.be/*",
    "*://*.vinted.pl/*",
    "*://*.vinted.es/*",
    "*://*.vinted.it/*",
    "*://*.vinted.nl/*",
    "*://*.vinted.lt/*",
    "*://*.vinted.cz/*",
    "*://*.vinted.sk/*",
    "*://*.vinted.hu/*",
    "*://*.vinted.ro/*",
    "*://*.vinted.at/*",
    "*://*.vinted.pt/*",
    "*://*.vinted.se/*",
    "*://*.vinted.fi/*",
    "*://*.vinted.dk/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.vinted.com/*",
        "*://*.vinted.fr/*",
        "*://*.vinted.de/*",
        "*://*.vinted.co.uk/*",
        "*://*.vinted.be/*",
        "*://*.vinted.pl/*",
        "*://*.vinted.es/*",
        "*://*.vinted.it/*",
        "*://*.vinted.nl/*",
        "*://*.vinted.lt/*",
        "*://*.vinted.cz/*",
        "*://*.vinted.sk/*",
        "*://*.vinted.hu/*",
        "*://*.vinted.ro/*",
        "*://*.vinted.at/*",
        "*://*.vinted.pt/*",
        "*://*.vinted.se/*",
        "*://*.vinted.fi/*",
        "*://*.vinted.dk/*"
      ],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vinted Relist Assistant",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
